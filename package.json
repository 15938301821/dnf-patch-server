{
  "name": "dnf-patch-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Auditable DNF patch factory orchestration service",
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build && npm run check:dist && npm run check:credentials:build",
    "check:credentials": "node scripts/check-credentials.mjs source",
    "check:credentials:build": "node scripts/check-credentials.mjs build",
    "check:dist": "node scripts/check-dist-imports.mjs",
    "check:migrations": "node scripts/check-migrations.mjs",
    "validate:project": "node scripts/validate-project.mjs",
    "test:smoke": "node scripts/smoke-dist.mjs",
    "test:startup-exceptions": "npm run build && node scripts/audit-startup-exceptions.mjs",
    "test:mysql": "npm run build && node scripts/test-mysql-runtime.mjs",
    "test:inventory-real": "npm run build && npm --prefix ../dnf-patch-worker run build && node scripts/test-inventory-real.mjs",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "tsc -p tsconfig.build.json && drizzle-kit generate",
    "db:migrate": "tsx src/common/db/migrate.ts",
    "gate": "npm run check:credentials && npm run validate:project && npm run typecheck && npm run lint && npm run test && npm run check:migrations && npm run build && npm run test:smoke"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1092.0",
    "@aws-sdk/s3-request-presigner": "^3.1092.0",
    "@nestjs/common": "11.1.28",
    "@nestjs/config": "4.0.4",
    "@nestjs/core": "11.1.28",
    "@nestjs/microservices": "11.1.28",
    "@nestjs/platform-fastify": "11.1.28",
    "@nestjs/platform-socket.io": "11.1.28",
    "@nestjs/websockets": "11.1.28",
    "cardinal": "2.1.1",
    "drizzle-orm": "0.45.2",
    "mysql2": "3.15.3",
    "openai": "6.48.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "socket.io": "4.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@nestjs/cli": "11.0.24",
    "@nestjs/platform-express": "11.1.28",
    "@nestjs/testing": "11.1.28",
    "@types/express": "^5.0.5",
    "@types/node": "24.10.1",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.7.4",
    "socket.io-client": "4.8.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.48.1",
    "vitest": "4.1.10",
    "ws": "^8.21.1"
  },
  "overrides": {
    "@fastify/ajv-compiler": {
      "ajv": "8.20.0"
    },
    "fast-json-stringify": {
      "ajv": "8.20.0"
    },
    "find-my-way": "9.7.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
