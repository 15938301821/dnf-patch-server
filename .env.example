NODE_ENV=development
HOST=localhost
PORT=3000
CORS_ORIGINS=http://localhost:3000

MYSQL_DATABASE=root 
MYSQL_ROOT_PASSWORD=replace-with-local-root-password
MYSQL_USER=dnf_patch
MYSQL_PASSWORD=replace-with-local-user-password

DATABASE_URL=mysql://dnf_patch:replace-with-local-user-password@127.0.0.1:3306/dnf_patch
DATABASE_POOL_SIZE=10

DNF_REPOSITORY_ROOT=../dnf-patch

CLIENT_SHARED_TOKEN=replace-with-at-least-32-random-characters

WORKER_SHARED_TOKEN=replace-with-a-different-32-character-token

OPENAI_API_KEY=replace-with-openai-api-key
OPENAI_BASE_URL=https://kldai.cc/v1
OPENAI_ORCHESTRATOR_MODEL=gpt-5.6-sol
OPENAI_ENGINEER_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_REQUEST_TIMEOUT_MS=180000
OPENAI_REQUEST_MAX_RETRIES=2
OUTBOX_DISPATCH_INTERVAL_MS=1000
OUTBOX_DISPATCH_BATCH_SIZE=25
WORKER_LEASE_SECONDS=60
WORKER_REAPER_INTERVAL_MS=5000
WORKER_REAPER_BATCH_SIZE=25
