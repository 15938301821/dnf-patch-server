MYSQL_ROOT_PASSWORD=replace-with-local-root-password
MYSQL_PASSWORD=replace-with-local-user-password

MINIO_ROOT_USER=replace-with-local-minio-root-user
MINIO_ROOT_PASSWORD=replace-with-at-least-32-random-characters
OBJECT_STORAGE_ENABLED=true
OBJECT_STORAGE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORAGE_REGION=us-east-1
OBJECT_STORAGE_BUCKET=dnf-patch-artifacts
OBJECT_STORAGE_ACCESS_KEY=replace-with-local-object-storage-app-user
OBJECT_STORAGE_SECRET_KEY=replace-with-a-different-32-character-secret
OBJECT_STORAGE_FORCE_PATH_STYLE=true
OBJECT_STORAGE_SIGNED_URL_TTL_SECONDS=300
OBJECT_STORAGE_MAX_OBJECT_BYTES=2147483648
OBJECT_STORAGE_MAX_RUN_BYTES=10737418240
ARTIFACT_ORPHAN_REAPER_INTERVAL_MS=30000
ARTIFACT_ORPHAN_REAPER_BATCH_SIZE=25

DATABASE_URL=mysql://root:replace-with-local-root-password@127.0.0.1:3306/dnf_patch

CLIENT_SHARED_TOKEN=replace-with-at-least-32-random-characters
WORKER_SHARED_TOKEN=replace-with-a-different-32-character-token
BROWSER_SESSION_SECRET=replace-with-a-third-32-character-random-secret
# 开启用户注册时配置；注册成功后用户使用自己的账号密码登录。
# USER_REGISTRATION_TOKEN=replace-with-a-fourth-32-character-random-token

# 用户模型 Key 使用 AES-256-GCM 加密；首次启动前生成并稳定保管 32 字节 base64url 主密钥，不得写入数据库。
MODEL_CREDENTIAL_MASTER_KEY=replace-with-32-byte-base64url-value
MODEL_CREDENTIAL_KEY_VERSION=v1

# 仅在已登记 Project/Snapshot 且受控 Worker 配置只读资源镜像后启用。
RESOURCE_IMPORT_SERVER_MIRROR_ENABLED=false
# RESOURCE_IMPORT_PROJECT_ID=00000000-0000-4000-8000-000000000000
# RESOURCE_IMPORT_SNAPSHOT_ID=00000000-0000-4000-8000-000000000000

# 模型调用使用每个用户在前端专用设置页提交的 BYOK Key；服务端不接受全局模型 Key。
