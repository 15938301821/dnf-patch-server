MYSQL_ROOT_PASSWORD=replace-with-local-root-password
MYSQL_PASSWORD=replace-with-local-user-password

DATABASE_URL=mysql://root:replace-with-local-root-password@127.0.0.1:3306/dnf_patch

CLIENT_SHARED_TOKEN=replace-with-at-least-32-random-characters
WORKER_SHARED_TOKEN=replace-with-a-different-32-character-token

# 仅在已登记 Project/Snapshot 且受控 Worker 配置只读资源镜像后启用。
RESOURCE_IMPORT_SERVER_MIRROR_ENABLED=false
# RESOURCE_IMPORT_PROJECT_ID=00000000-0000-4000-8000-000000000000
# RESOURCE_IMPORT_SNAPSHOT_ID=00000000-0000-4000-8000-000000000000

# 需要模型调用时再启用；不配置时服务会阻断外发模型请求。
# OPENAI_API_KEY=replace-with-openai-api-key
