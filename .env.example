NODE_ENV=development
HOST=127.0.0.1
PORT=56789
CORS_ORIGINS=http://127.0.0.1:5173
MYSQL_DATABASE=dnf_patch
MYSQL_USER=dnf_patch
MYSQL_PASSWORD=replace-with-a-local-database-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-root-password
DATABASE_URL=mysql://dnf_patch:replace-with-a-local-database-password@127.0.0.1:3306/dnf_patch
DATABASE_POOL_SIZE=10
DNF_REPOSITORY_ROOT=../dnf-patch
CLIENT_SHARED_TOKEN=replace-with-at-least-32-random-characters
WORKER_SHARED_TOKEN=replace-with-a-different-32-character-token
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORCHESTRATOR_MODEL=gpt-5.6-sol
OPENAI_ENGINEER_MODEL=gpt-5.5
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_REQUEST_TIMEOUT_MS=180000
OPENAI_REQUEST_MAX_RETRIES=2
WORKER_LEASE_SECONDS=60
